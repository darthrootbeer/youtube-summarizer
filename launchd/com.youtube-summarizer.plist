<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.youtube-summarizer</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>export PATH="/opt/homebrew/bin:/opt/homebrew/sbin:$PATH" &amp;&amp; cd "__PROJECT_PATH__" &amp;&amp; source .venv/bin/activate &amp;&amp; python -m youtube_summarizer watch --poll-seconds 900 --limit 10</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/youtube-summarizer.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/youtube-summarizer.err.log</string>
  </dict>
</plist>
