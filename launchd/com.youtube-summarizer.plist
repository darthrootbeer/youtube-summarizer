<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
  <dict>
    <key>Label</key>
    <string>com.youtube-summarizer</string>

    <key>ProgramArguments</key>
    <array>
      <string>/bin/zsh</string>
      <string>-lc</string>
      <string>cd "$HOME/projects/youtube-summarizer" &amp;&amp; source .venv/bin/activate &amp;&amp; python -m youtube_summarizer run</string>
    </array>

    <key>StartInterval</key>
    <integer>21600</integer>

    <key>StandardOutPath</key>
    <string>/tmp/youtube-summarizer.out.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/youtube-summarizer.err.log</string>
  </dict>
</plist>
