<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ subject }}</title>
    <style>
      p { margin: 0 0 12px 0; }
      ul { margin: 4px 0 14px 0; padding: 0; list-style: none; }
      li { margin: 0 0 8px 0; padding-left: 18px; position: relative; }
      li::before { content: "–"; position: absolute; left: 0; color: #7c85c0; font-weight: 600; }
    </style>
  </head>
  <body style="margin:0;padding:0;background:#eaecf5;font-family:ui-sans-serif,system-ui,-apple-system,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;">

    <!-- Outer wrapper -->
    <div style="max-width:680px;margin:0 auto;padding:36px 16px 28px;">

      <!-- Card -->
      <div style="background:#ffffff;border-radius:18px;overflow:hidden;box-shadow:0 8px 32px rgba(15,18,45,0.12),0 2px 6px rgba(15,18,45,0.06);">

        <!-- Header: deep gradient -->
        <div style="background:linear-gradient(140deg,#0d1021 0%,#1b2048 60%,#232d6a 100%);padding:26px 30px 22px;">
          <div style="font-size:10.5px;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,0.45);margin-bottom:12px;font-weight:500;">
            {{ source_label }}&ensp;&middot;&ensp;{{ source_name }}
          </div>
          <div style="font-size:23px;font-weight:700;color:#ffffff;line-height:1.28;letter-spacing:-.02em;">
            {{ video_title }}
          </div>
        </div>

        <!-- Thumbnail -->
        {% if thumbnail_url %}
        <a href="{{ video_url }}" style="display:block;line-height:0;border:0;outline:0;">
          <img src="{{ thumbnail_url }}"
               alt="{{ video_title }}"
               width="100%"
               style="display:block;border:0;max-height:340px;width:100%;object-fit:cover;" />
        </a>
        {% endif %}

        <!-- Video meta strip -->
        <div style="padding:13px 30px;background:#f2f3fa;border-bottom:1px solid #e0e3f0;">
          <span style="font-size:12.5px;color:#4a4f70;line-height:1.5;">
            <span style="font-weight:600;color:#22253d;">{{ source_name }}</span>
            {% if published_at_display %}
            &ensp;<span style="color:#9096bb;">&middot;</span>&ensp;<span>{{ published_at_display }}</span>
            {% endif %}
            {% if video_duration_display %}
            &ensp;<span style="color:#9096bb;">&middot;</span>&ensp;<span>{{ video_duration_display }}</span>
            {% endif %}
            &ensp;<span style="color:#9096bb;">&middot;</span>&ensp;<a href="{{ video_url }}" style="color:#4b6cf6;text-decoration:none;font-weight:500;">Watch&nbsp;video&nbsp;&#8599;</a>
          </span>
        </div>

        <!-- Content -->
        <div style="padding:28px 30px 8px;">

          {% for s in sections %}

          {% if s.style == "opener" %}
          <!-- Opener: headline block -->
          <div style="margin-bottom:26px;padding-left:16px;border-left:3px solid #4b6cf6;">
            <div style="font-size:22px;font-weight:600;color:#1e2138;line-height:1.4;">
              {{ s.html }}
            </div>
          </div>

          {% elif s.style == "transcript" %}
          <!-- Transcript block: smaller font -->
          <div style="margin-bottom:24px;padding-top:24px;border-top:1px solid #e8eaf4;">
            <div style="font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#9096bb;margin-bottom:16px;">{{ s.label }}</div>
            <div style="font-size:14px;color:#1e2138;line-height:1.68;">
              {{ s.html }}
            </div>
          </div>

          {% else %}
          <!-- Body block: summary, glossary, outline -->
          <div style="margin-bottom:24px;{% if not loop.first %}padding-top:24px;border-top:1px solid #e8eaf4;{% endif %}">
            {% if s.label %}
            <div style="font-size:10px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:#9096bb;margin-bottom:16px;">{{ s.label }}</div>
            {% endif %}
            <div style="font-size:16px;color:#1e2138;line-height:1.5;">
              {{ s.html }}
            </div>
          </div>
          {% endif %}

          {% endfor %}

          <!-- Debug stats -->
          {% if beta_stats %}
          <div style="margin-top:16px;padding-top:20px;border-top:1px solid #e8eaf4;">
            <div style="font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#a0a6c8;margin-bottom:10px;">Debug stats</div>
            <div style="font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace;font-size:11px;color:#7178a0;white-space:pre-wrap;line-height:1.55;">summary_id: {{ beta_stats.summary_id }}
video_id: {{ beta_stats.video_id }}
transcript_source: {{ beta_stats.transcript_source }}
enabled_prompts: {{ beta_stats.enabled_prompts or "n/a" }}
prompt_tier: {{ beta_stats.prompt_tier or "n/a" }}
prompt_count: {{ beta_stats.prompt_count or "n/a" }}
per_prompt_summarize_s: {{ beta_stats.per_prompt_summarize_s or "n/a" }}
transcript_chars: {{ beta_stats.transcript_chars or "n/a" }}
summary_chars: {{ beta_stats.summary_chars or "n/a" }}
mode: {{ beta_stats.mode or "n/a" }}
ollama_model: {{ beta_stats.ollama_model or "n/a" }}
rss_fetch_s: {{ beta_stats.rss_fetch_s or "n/a" }}
media_size_mb: {{ beta_stats.media_size_mb or "n/a" }}
download_media_s: {{ beta_stats.download_media_s or "n/a" }}
video_duration_s: {{ beta_stats.video_duration_s | round(1) if beta_stats.video_duration_s else "n/a" }}
transcribe_s: {{ beta_stats.transcribe_s or "n/a" }}
summarize_s: {{ beta_stats.summarize_s or "n/a" }}
avg_cpu_pct: {{ beta_stats.avg_cpu_pct or "n/a" }}
has_description: {{ beta_stats.has_description }}
chapters_count: {{ beta_stats.chapters_count }}
email_render_s: {{ beta_stats.email_render_s or "n/a" }}
email_send_s: {{ beta_stats.email_send_s or "n/a" }}
total_before_send_s: {{ beta_stats.total_before_send_s or "n/a" }}
total_to_send_s: {{ beta_stats.total_to_send_s or "n/a" }}
total_processing_s: {{ beta_stats.total_processing_s or "n/a" }}
qa_notes: {{ beta_stats.qa_notes or "" }}</div>
          </div>
          {% endif %}

        </div>
      </div>

      <!-- Footer -->
      <div style="text-align:center;margin-top:20px;">
        <span style="font-size:11px;color:#a0a6c8;letter-spacing:.05em;text-transform:uppercase;font-weight:500;">YouTube Summarizer</span>
      </div>

    </div>
  </body>
</html>
