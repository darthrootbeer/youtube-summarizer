<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ subject }}</title>
  </head>
  <body style="margin:0;padding:0;background:#f6f7fb;">
    <div style="max-width:720px;margin:0 auto;padding:28px 16px;">
      <div style="background:#ffffff;border:1px solid #e7e9f2;border-radius:14px;overflow:hidden;">
        <div style="padding:18px 20px;background:#121526;color:#ffffff;">
          <div style="font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial; font-size:14px; opacity:.9;">
            {{ channel_name }}
          </div>
          <div style="font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial; font-size:20px; font-weight:700; margin-top:6px; line-height:1.25;">
            {{ video_title }}
          </div>
        </div>

        <div style="padding:18px 20px;">
          <div style="font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial; font-size:14px; color:#1a1d2a; line-height:1.6;">
            <div style="margin-bottom:14px;">
              <a href="{{ video_url }}" style="color:#2b59ff; text-decoration:none; font-weight:600;">
                Watch on YouTube →
              </a>
            </div>

            <div style="margin:16px 0; padding:14px 14px; border:1px solid #eef0f7; border-radius:12px; background:#fbfbfe;">
              <div style="font-size:12px; letter-spacing:.06em; text-transform:uppercase; color:#6b6f85; margin-bottom:8px;">
                Summary
              </div>
              <div style="white-space:pre-wrap;">{{ summary }}</div>
            </div>

            <div style="font-size:12px; color:#6b6f85;">
              Transcript source: <strong style="color:#3b3f55;">{{ transcript_source }}</strong>
              {% if published_at %}
              · Published: {{ published_at }}
              {% endif %}
            </div>
          </div>
        </div>
      </div>

      <div style="font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial; font-size:12px; color:#7c8096; margin-top:14px; text-align:center;">
        Sent by YouTube Summarizer
      </div>
    </div>
  </body>
</html>
