<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ subject }}</title>
  </head>
  <body style="margin:0;padding:0;background:#f6f7fb;">
    <div style="max-width:720px;margin:0 auto;padding:28px 16px;">
      <div style="background:#ffffff;border:1px solid #e7e9f2;border-radius:14px;overflow:hidden;">

        <!-- Header -->
        <div style="padding:18px 20px;background:#121526;color:#ffffff;">
          <div style="font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial; font-size:11px; letter-spacing:.08em; text-transform:uppercase; opacity:.6; margin-bottom:4px;">
            {{ source_label }} · {{ source_name }}
          </div>
          <div style="font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial; font-size:20px; font-weight:700; line-height:1.25;">
            {{ video_title }}
          </div>
        </div>

        <!-- Thumbnail -->
        {% if thumbnail_url %}
        <a href="{{ video_url }}" style="display:block; line-height:0;">
          <img src="{{ thumbnail_url }}"
               alt="{{ video_title }}"
               width="100%"
               style="display:block; border:0; max-height:360px; object-fit:cover;" />
        </a>
        {% endif %}

        <!-- Video meta -->
        <div style="padding:12px 20px; background:#f9fafc; border-bottom:1px solid #e7e9f2;">
          <div style="font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial; font-size:13px; color:#3b3f55; line-height:1.7;">
            <div><strong>Channel:</strong> {{ source_name }}</div>
            {% if published_at_display %}
            <div><strong>Published:</strong> {{ published_at_display }}</div>
            {% endif %}
            <div>
              <strong>URL:</strong>
              <a href="{{ video_url }}" style="color:#2b59ff; text-decoration:none;">{{ video_url }}</a>
            </div>
          </div>
        </div>

        <!-- Content -->
        <div style="padding:18px 20px;">
          <div style="font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial; font-size:14px; color:#1a1d2a; line-height:1.6;">

            {% for s in sections %}
            <div style="margin:16px 0; padding:14px 14px; border:1px solid #eef0f7; border-radius:12px; background:#fbfbfe;">
              <div style="font-size:12px; letter-spacing:.06em; text-transform:uppercase; color:#6b6f85; margin-bottom:8px;">
                {{ s.label }}
              </div>
              <div>{{ s.html }}</div>
            </div>
            {% if not loop.last %}
            <div style="border-top:1px solid #eef0f7; margin:14px 0;"></div>
            {% endif %}
            {% endfor %}

            <div style="font-size:12px; color:#6b6f85; margin-top:14px;">
              Transcript source: <strong style="color:#3b3f55;">{{ transcript_source }}</strong>
            </div>

            {% if beta_stats %}
            <div style="margin-top:14px; padding-top:12px; border-top:1px solid #eef0f7; font-size:12px; color:#6b6f85;">
              <div style="font-size:11px; letter-spacing:.06em; text-transform:uppercase; color:#6b6f85; margin-bottom:6px;">
                Beta stats
              </div>
              <div style="font-family:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace; white-space:pre-wrap; line-height:1.45;">
summary_id: {{ beta_stats.summary_id }}
video_id: {{ beta_stats.video_id }}
transcript_source: {{ beta_stats.transcript_source }}
enabled_prompts: {{ beta_stats.enabled_prompts or "n/a" }}
prompt_count: {{ beta_stats.prompt_count or "n/a" }}
per_prompt_summarize_s: {{ beta_stats.per_prompt_summarize_s or "n/a" }}
transcript_chars: {{ beta_stats.transcript_chars or "n/a" }}
summary_chars: {{ beta_stats.summary_chars or "n/a" }}
mode: {{ beta_stats.mode or "n/a" }}
ollama_model: {{ beta_stats.ollama_model or "n/a" }}
rss_fetch_s: {{ beta_stats.rss_fetch_s or "n/a" }}
media_size_mb: {{ beta_stats.media_size_mb or "n/a" }}
download_media_s: {{ beta_stats.download_media_s or "n/a" }}
transcribe_s: {{ beta_stats.transcribe_s or "n/a" }}
summarize_s: {{ beta_stats.summarize_s or "n/a" }}
email_render_s: {{ beta_stats.email_render_s or "n/a" }}
email_send_s: {{ beta_stats.email_send_s or "n/a" }}
total_before_send_s: {{ beta_stats.total_before_send_s or "n/a" }}
total_to_send_s: {{ beta_stats.total_to_send_s or "n/a" }}
total_processing_s: {{ beta_stats.total_processing_s or "n/a" }}
qa_notes: {{ beta_stats.qa_notes or "" }}
              </div>
            </div>
            {% endif %}
          </div>
        </div>
      </div>

      <div style="font-family:ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial; font-size:12px; color:#7c8096; margin-top:14px; text-align:center;">
        Sent by YouTube Summarizer
      </div>
    </div>
  </body>
</html>
