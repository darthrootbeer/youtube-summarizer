# Gmail SMTP (recommended: App Password)
YTS_EMAIL_FROM="yourname@gmail.com"
YTS_EMAIL_TO="yourname@gmail.com"
YTS_GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# Optional email subject prefix (helps filtering)
YTS_SUBJECT_PREFIX="[YT Summary] "

# Optional: enable local Ollama summaries (free)
# Example: YTS_OLLAMA_MODEL="qwen2.5:14b"
# If unset, we use a simple placeholder summary.
YTS_OLLAMA_MODEL="qwen2.5:14b"

# Optional: enable AI cleanup for transcribe-mode emails (uses config/transcribe.md)
# Recommended: leave off for maximum transcript accuracy.
# YTS_TRANSCRIPT_CLEAN_WITH_OLLAMA="1"

# Transcription fallback (used only when YouTube has no transcript)
#
# Recommended: Parakeet v3 (very fast on Apple Silicon) via `parakeet-mlx`
#   pip install -r requirements.txt
#   brew install ffmpeg
#
# Options:
# - parakeet_mlx (default)
# - whisper_cpp
YTS_TRANSCRIBE_BACKEND="parakeet_mlx"

# Parakeet v3 model (Hugging Face repo id)
# Default is Parakeet-TDT v3.
YTS_PARAKEET_MODEL="mlx-community/parakeet-tdt-0.6b-v3"

# whisper.cpp alternative (if you choose whisper_cpp backend)
#   brew install whisper-cpp
#   download a ggml model and set the path
# YTS_WHISPER_CPP_MODEL="/path/to/ggml-base.en.bin"

# If YouTube blocks automated downloads, yt-dlp may require browser cookies.
# Choose ONE of these:
# YTS_YTDLP_COOKIES_FROM_BROWSER="chrome"
YTS_YTDLP_COOKIES_FROM_BROWSER="safari"
# OR:
# YTS_YTDLP_COOKIES_FILE="/absolute/path/to/cookies.txt"
